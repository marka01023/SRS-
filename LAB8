-------
CREATE TABLE lab8_schema.customers (
    customer_id SERIAL PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    email VARCHAR(100) UNIQUE
);


------
CREATE TABLE lab8_schema.orders (
    order_id SERIAL PRIMARY KEY,
    customer_id INT NOT NULL,
    order_date DATE DEFAULT CURRENT_DATE,

    CONSTRAINT fk_customer
    FOREIGN KEY (customer_id)
    REFERENCES lab8_schema.customers(customer_id)
    ON DELETE CASCADE
);

-----

ALTER TABLE lab8_schema.customers
ADD CONSTRAINT chk_email
CHECK (email LIKE '%@%');

-- Тапсырыс күні болашақта болмауы керек
ALTER TABLE lab8_schema.orders
ADD CONSTRAINT chk_order_date
CHECK (order_date <= CURRENT_DATE);

