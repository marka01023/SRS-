SELECT *
FROM lab8_schema.orders o
LEFT JOIN lab8_schema.customers c
ON o.customer_id = c.customer_id
WHERE c.customer_id IS NULL;

------
CREATE VIEW lab8_schema.v_order_summary AS
SELECT
    c.name,
    COUNT(o.order_id) AS total_orders
FROM lab8_schema.customers c
LEFT JOIN lab8_schema.orders o
ON c.customer_id = o.customer_id
GROUP BY c.name;

--=----
GRANT SELECT
ON lab8_schema.v_order_summary
TO lab8_user;
